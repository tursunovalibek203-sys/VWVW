; Performance optimization for faster npm install
registry=https://registry.npmjs.org/
legacy-peer-deps=true
maxsockets=32
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

; Enable npm cache
cache-min=999999

; Disable audit for faster install
audit=false

; Use workspace when available
workspaces-update=true
