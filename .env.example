# ============================================
# MULTI-LAPTOP SETUP - Copy to .env and customize per laptop
# ============================================

# DEVICE CONFIGURATION (HAR NOUTBUK UCHUN O'ZGARTIRING)
# -----------------------------------------------------
# Laptop 1: VITE_DEVICE_ID=laptop_1, VITE_DEVICE_NAME="Asosiy Kassa"
# Laptop 2: VITE_DEVICE_ID=laptop_2, VITE_DEVICE_NAME="Zaxira Kassa"
# Laptop 3: VITE_DEVICE_ID=laptop_3, VITE_DEVICE_NAME="Ombor Kassa"

VITE_DEVICE_ID=laptop_1
VITE_DEVICE_NAME="Asosiy Kassa"

# SUPABASE CONFIGURATION (BARCHA NOUTBUKLAR UCHUN BIR XIL)
# ---------------------------------------------------------
# XAVFSIZLIK: Bu yerda real credentials yo'q, .env faylida qo'ying
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# DATABASE - PostgreSQL (prisma/schema.prisma provider = postgresql)
# ------------------------------------------------------------------
# Local dev (default): local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aziztrades_erp?schema=public"
#
# Production - connection pool parametrlari bilan:
# DATABASE_URL="postgresql://user:password@host:port/database?connection_limit=50&pool_timeout=30"

# SERVER CONFIGURATION
# ---------------------
# 5003 = vite.config.ts proxy target (o'zgartirsangiz proxy'ni ham yangilang)
PORT=5003
NODE_ENV=development

# JWT SECRET (MUHIM: Production da kuchli secret ishlatish kerak!)
# ----------------------------------------------------------------
# Development uchun: Kamida 32 ta belgi
# Production uchun: 64+ ta belgi, random, murakkab
# Generator: openssl rand -base64 64
JWT_SECRET="dev-lux-pet-plast-2024-jwt-secret-change-this-in-production-min-32-chars"

# USER PASSWORDS (For initial user creation scripts)
# ------------------------------------------------
# Change these before running create-admin.cjs or create-test-users.ts
ADMIN_PASSWORD="change-this-admin-password"
CASHIER_PASSWORD="change-this-cashier-password"
SELLER_PASSWORD="change-this-seller-password"

# TELEGRAM BOTS (OPTIONAL)
# -----------------------
TELEGRAM_CUSTOMER_BOT_TOKEN=""
TELEGRAM_DRIVER_BOT_TOKEN=""
TELEGRAM_ADMIN_BOT_TOKEN=""

# GEMINI AI CONFIGURATION
# -----------------------
GEMINI_API_KEY="your-google-gemini-api-key-here"

# EXCHANGE RATES
# --------------
USD_TO_UZS_RATE=12500

# RAILWAY.DEPLOYMENT SPECIFIC
# ---------------------------
# These variables will be set automatically by Railway
# DATABASE_URL - Set by Railway PostgreSQL service
# REDIS_URL - Set by Railway Redis service
# JWT_SECRET - Generate in Railway dashboard
# PORT - Railway sets this automatically

# TELEGRAM BOT (Required for background worker)
# --------------------------------------------
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"
