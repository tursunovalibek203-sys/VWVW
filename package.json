{
  "name": "luxpetplast-erp",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "build:prod": "npm run build:client && npm run db:generate",
    "build:client": "vite build",
    "preview": "vite preview",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:full": "tsx scripts/seed-full.ts",
    "migrate:variants": "tsx scripts/migrate-to-variants.ts",
    "migrate:variants:preview": "tsx scripts/migrate-to-variants.ts preview",
    "migrate:variants:execute": "tsx scripts/migrate-to-variants.ts execute",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "start": "node dist-server/index.js",
    "start:prod": "NODE_ENV=production node dist-server/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop luxpetplast-erp",
    "pm2:restart": "pm2 restart luxpetplast-erp",
    "pm2:logs": "pm2 logs luxpetplast-erp",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome'",
    "playwright:install": "playwright install --with-deps",
    "db:add:data": "node add_data_terminal.cjs",
    "db:sql": "sqlite3 prisma/dev.db",
    "db:sql:import": "sqlite3 prisma/dev.db < add_data_example.sql",
    "db:sql:kapsula": "sqlite3 prisma/dev.db < add_kapsula_products.sql",
    "db:sql:kapsula:full": "sqlite3 prisma/dev.db < add_kapsula_products_with_types.sql",
    "db:sql:kapsula:safe": "sqlite3 prisma/dev.db < add_kapsula_safe.sql",
    "cap:init": "npx cap init \"Zavod Tizimi\" com.zavod.app --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "tauri:dev": "tauri dev",
    "test": "jest",
    "test:unit": "jest --testPathPattern='services|utils|middleware' --coverage",
    "test:api": "jest --testPathPattern='api/' --testTimeout=30000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "verify:production": "tsx scripts/verify-production-safety.ts",
    "test:stress": "tsx scripts/stress-test-concurrency.ts",
    "db:constraints": "psql $DATABASE_URL -f scripts/apply-safety-constraints.sql"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^7.100.0",
    "@supabase/supabase-js": "^2.103.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/xlsx": "^0.0.35",
    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "buffer": "^6.0.3",
    "bullmq": "^5.1.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "crewai-ts": "^0.2.0",
    "csurf": "^1.11.0",
    "date-fns": "^3.3.1",
    "decimal.js": "^10.6.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.3.1",
    "lucide-react": "^0.344.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.34.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^14.0.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^2.2.1",
    "uuid": "^9.0.1",
    "uzbek-transliterator": "^0.0.7",
    "vis-network": "^10.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.6.2",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "postcss": "^8.4.35",
    "prisma": "^5.9.1",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
