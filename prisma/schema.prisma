generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  login     String   @unique
  password  String
  name      String
  role      String   @default("SELLER")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
}

model Product {
  id              String   @id @default(uuid())
  name            String   @unique
  bagType         String
  unitsPerBag     Float    @default(1000)
  minStockLimit   Int
  optimalStock    Int
  maxCapacity     Int
  currentStock    Float    @default(0)
  currentUnits    Float    @default(0)
  pricePerBag     Float
  pricePerPiece   Float    @default(0)
  productionCost  Float    @default(0)
  isParent        Boolean  @default(false)
  parentProductId String?
  variantName     String?
  productTypeId   String?
  warehouse       String   @default("preform")
  categoryId      String?
  sizeId          String?
  subType         String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  saleItems       SaleItem[]
  batches         Batch[]
  variants        ProductVariant[]

  @@index([name])
  @@index([active])
  @@index([warehouse])
  @@index([categoryId])
  @@index([productTypeId])
  @@index([createdAt])
}

model Batch {
  id                String   @id @default(uuid())
  productId         String
  quantity          Int
  productionDate    DateTime
  shift             String
  responsiblePerson String
  createdAt         DateTime @default(now())

  product           Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Customer {
  id                   String    @id @default(uuid())
  name                 String
  email                String?   @unique
  phone                String
  address              String?
  telegramChatId       String?   @unique
  telegramUsername     String?
  notificationsEnabled Boolean   @default(true)
  debtReminderDays     Int       @default(7)
  category             String    @default("NORMAL")
  balance              Float     @default(0)
  balanceUZS           Float     @default(0)
  balanceUSD           Float     @default(0)
  debt                 Float     @default(0)
  debtUZS              Float     @default(0)
  debtUSD              Float     @default(0)
  creditLimit          Float     @default(0)
  paymentTermDays      Int       @default(30)
  discountPercent      Float     @default(0)
  pricePerBag          Float?
  productPrices        String?
  lastPurchase         DateTime?
  lastPayment          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  sales                Sale[]
}

model Sale {
  id                    String   @id @default(uuid())
  receiptNumber         Int      @default(0)
  customerId            String?
  productId             String?
  userId                String
  driverId              String?
  quantity              Float    @default(1)
  pricePerBag           Float    @default(0)
  bagType               String   @default("SMALL")
  totalAmount           Float
  paidAmount            Float    @default(0)
  currency              String   @default("USD")
  paymentStatus         String   @default("UNPAID")
  paymentDetails        String?
  driverPaymentStatus   String   @default("PENDING")
  driverCollectedAmount Float    @default(0)
  factoryShare          Float    @default(0)
  customerShare         Float    @default(0)
  isKocha               Boolean  @default(false)
  manualCustomerName    String?
  manualCustomerPhone   String?
  createdAt             DateTime @default(now())
  paymentMethod         String?  @default("CASH")

  customer              Customer? @relation(fields: [customerId], references: [id])
  user                  User      @relation(fields: [userId], references: [id])
  driver                Driver?   @relation(fields: [driverId], references: [id])
  items                 SaleItem[]

  @@index([customerId])
  @@index([productId])
  @@index([userId])
  @@index([driverId])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([receiptNumber])
  @@index([createdAt, customerId])
  @@index([isKocha, createdAt])
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String?
  variantId   String?
  quantity    Float
  pricePerBag Float
  subtotal    Float
  saleType    String?

  sale        Sale     @relation(fields: [saleId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([variantId])
}

model Invoice {
  id             String   @id @default(uuid())
  saleId         String   @unique
  customerId     String
  invoiceNumber  String   @unique
  totalAmount    Float
  currency       String
  sentToTelegram Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([customerId])
}

model Payment {
  id             String   @id @default(uuid())
  customerId     String
  amount         Float
  currency       String
  description    String?
  paymentDetails String?
  createdAt      DateTime @default(now())

  @@index([customerId])
}

model CustomerPayment {
  id         String   @id @default(uuid())
  customerId String
  amount     Float
  currency   String   @default("UZS")
  type       String   @default("CASH")
  notes      String?
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model Expense {
  id          String   @id @default(uuid())
  category    String
  amount      Float
  currency    String
  description String
  userId      String
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}

model StockAlert {
  id        String   @id @default(uuid())
  productId String
  alertType String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([resolved])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}

model SalesForecast {
  id              String   @id @default(uuid())
  productId       String
  forecastDate    DateTime
  predictedDemand Int
  confidence      Float
  createdAt       DateTime @default(now())

  @@index([productId])
  @@index([forecastDate])
}

model Contract {
  id              String   @id @default(uuid())
  customerId      String
  contractNumber  String   @unique
  startDate       DateTime
  endDate         DateTime
  terms           String
  creditLimit     Float
  paymentTermDays Int
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([customerId])
}

model PriceLevel {
  id              String   @id @default(uuid())
  productId       String
  name            String
  minQuantity     Int
  price           Float
  discountPercent Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([productId])
}

model CashierShift {
  id             String    @id @default(uuid())
  userId         String
  openingBalance Float
  closingBalance Float?
  cashSales      Float     @default(0)
  cardSales      Float     @default(0)
  clickSales     Float     @default(0)
  totalSales     Float     @default(0)
  shortage       Float     @default(0)
  overage        Float     @default(0)
  startTime      DateTime  @default(now())
  endTime        DateTime?
  status         String    @default("OPEN")

  @@index([userId])
  @@index([startTime])
}

model Delivery {
  id            String    @id @default(uuid())
  saleId        String    @unique
  driverId      String?
  address       String
  scheduledDate DateTime
  deliveredDate DateTime?
  status        String    @default("PENDING")
  cost          Float     @default(0)
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([driverId])
  @@index([status])
}

model Driver {
  id               String   @id @default(uuid())
  userId           String?
  name             String
  phone            String   @unique
  licenseNumber    String?
  vehicleNumber    String
  telegramChatId   String?  @unique
  telegramUsername String?
  status           String   @default("AVAILABLE")
  active           Boolean  @default(true)
  rating           Float    @default(5.0)
  totalDeliveries  Int      @default(0)
  currentLocation  String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sales            Sale[]
}

model DeliveryAssignment {
  id              String    @id @default(uuid())
  orderId         String
  driverId        String
  assignedBy      String
  status          String    @default("PENDING")
  assignedAt      DateTime  @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  rejectionReason String?
  notes           String?
  customerPhone   String?
  deliveryAddress String
  estimatedTime   Int?
  actualTime      Int?

  @@index([driverId])
  @@index([orderId])
  @@index([status])
}

model DriverChat {
  id          String   @id @default(uuid())
  driverId    String
  adminId     String
  message     String
  senderType  String
  messageType String   @default("TEXT")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([driverId])
  @@index([adminId])
  @@index([createdAt])
}

model DriverLocation {
  id        String   @id @default(uuid())
  driverId  String
  latitude  Float
  longitude Float
  address   String?
  speed     Float?
  heading   Float?
  accuracy  Float?
  timestamp DateTime @default(now())

  @@index([driverId])
  @@index([timestamp])
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String
  email         String?
  phone         String
  address       String?
  paymentTerms  String   @default("30 days")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RawMaterial {
  id            String   @id @default(uuid())
  name          String
  unit          String
  currentStock  Float    @default(0)
  minStockLimit Float
  unitPrice     Float
  supplierId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([supplierId])
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  orderNumber  String    @unique
  supplierId   String
  totalAmount  Float
  status       String    @default("PENDING")
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String @id @default(uuid())
  purchaseOrderId String
  rawMaterialId   String
  quantity        Float
  unitPrice       Float
  subtotal        Float

  @@index([purchaseOrderId])
  @@index([rawMaterialId])
}

model ProductionOrder {
  id             String    @id @default(uuid())
  orderNumber    String    @unique
  productId      String
  targetQuantity Int
  actualQuantity Int       @default(0)
  status         String    @default("PLANNED")
  plannedDate    DateTime
  startedDate    DateTime?
  completedDate  DateTime?
  shift          String
  supervisorId   String
  notes          String?
  createdAt      DateTime  @default(now())

  @@index([productId])
  @@index([status])
  @@index([supervisorId])
}

model ProductionUsage {
  id                String   @id @default(uuid())
  productionOrderId String
  rawMaterialId     String
  quantityUsed      Float
  createdAt         DateTime @default(now())

  @@index([productionOrderId])
  @@index([rawMaterialId])
}

model QualityCheck {
  id        String   @id @default(uuid())
  productId String
  batchId   String?
  checkType String
  status    String
  checkedBy String
  checkDate DateTime @default(now())
  defects   String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([status])
  @@index([checkDate])
}

model Promotion {
  id          String   @id @default(uuid())
  name        String
  description String
  type        String
  value       Float
  minQuantity Int?
  maxQuantity Int?
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([active])
  @@index([startDate])
  @@index([endDate])
}

model LoyaltyProgram {
  id           String   @id @default(uuid())
  customerId   String
  points       Int      @default(0)
  totalSpent   Float    @default(0)
  tier         String   @default("BRONZE")
  joinDate     DateTime @default(now())
  lastActivity DateTime @default(now())

  @@index([customerId])
  @@index([tier])
}

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  loyaltyId   String
  type        String
  points      Int
  description String
  saleId      String?
  createdAt   DateTime @default(now())

  @@index([loyaltyId])
  @@index([type])
}

model Maintenance {
  id              String    @id @default(uuid())
  equipmentName   String
  maintenanceType String
  description     String
  scheduledDate   DateTime
  completedDate   DateTime?
  cost            Float     @default(0)
  technician      String
  status          String    @default("SCHEDULED")
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([scheduledDate])
}

model Task {
  id            String    @id @default(uuid())
  title         String
  description   String?
  assignedTo    String
  priority      String    @default("MEDIUM")
  status        String    @default("TODO")
  dueDate       DateTime?
  completedDate DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([assignedTo])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String
  updatedAt   DateTime @updatedAt
}

model Card {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  defaultCard String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductCategory {
  id            String   @id @default(uuid())
  name          String
  description   String?
  icon          String?
  color         String?
  active        Boolean  @default(true)
  productTypeId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, productTypeId])
}

model ProductSize {
  id          String   @id @default(uuid())
  name        String
  description String?
  unit        String
  value       Float
  active      Boolean  @default(true)
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, categoryId])
}

model CardProduct {
  id        String   @id @default(uuid())
  cardId    String
  productId String
  quantity  Int      @default(1)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([cardId, productId])
}

model StockMovement {
  id            String   @id @default(uuid())
  productId     String
  type          String
  quantity      Int
  units         Int
  reason        String
  userId        String
  userName      String
  previousStock Int
  previousUnits Int
  newStock      Int
  newUnits      Int
  notes         String?
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model Order {
  id               String    @id @default(uuid())
  orderNumber      String    @unique
  customerId       String
  status           String    @default("PENDING")
  priority         String    @default("NORMAL")
  requestedDate    DateTime
  promisedDate     DateTime?
  deliveredDate    DateTime?
  confirmedAt      DateTime?
  soldAt           DateTime?
  totalAmount      Float     @default(0)
  paidAmount       Float     @default(0)
  paymentDetails   String?
  saleId           String?
  notes            String?
  aiRecommendation String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([requestedDate])
  @@index([createdAt])
  @@index([priority])
  @@index([status, createdAt])
  @@index([customerId, status])
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String?
  variantId     String?
  quantityBags  Int
  quantityUnits Int
  pricePerBag   Float
  subtotal      Float
  notes         String?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model ProductionPlan {
  id              String   @id @default(uuid())
  orderId         String   @unique
  planType        String
  startDate       DateTime
  endDate         DateTime
  totalBags       Int
  totalUnits      Int
  status          String   @default("DRAFT")
  aiConfidence    Float    @default(0)
  inventoryCheck  String?
  recommendations String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([startDate])
}

model ProductionTask {
  id            String    @id @default(uuid())
  planId        String
  productId     String
  productName   String
  quantityBags  Int
  quantityUnits Int
  priority      Int       @default(1)
  status        String    @default("PENDING")
  assignedTo    String?
  startTime     DateTime?
  endTime       DateTime?
  notes         String?

  @@index([planId])
  @@index([status])
}

model Vehicle {
  id              String    @id @default(uuid())
  plateNumber     String    @unique
  type            String
  model           String
  capacity        Float
  status          String    @default("AVAILABLE")
  fuelType        String
  lastMaintenance DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DriverNew {
  id              String   @id @default(uuid())
  name            String
  phone           String   @unique
  licenseNumber   String   @unique
  licenseExpiry   DateTime
  telegramChatId  String?
  status          String   @default("AVAILABLE")
  rating          Float    @default(5.0)
  totalDeliveries Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DeliveryNew {
  id            String    @id @default(uuid())
  saleId        String    @unique
  vehicleId     String?
  driverId      String?
  fromAddress   String    @default("Zavod")
  toAddress     String
  distance      Float?
  scheduledDate DateTime
  departureTime DateTime?
  arrivalTime   DateTime?
  status        String    @default("PENDING")
  notes         String?
  customerPhone String?
  deliveryProof String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DeliveryStatusHistory {
  id         String   @id @default(uuid())
  deliveryId String
  status     String
  notes      String?
  location   String?
  createdAt  DateTime @default(now())
}

model VehicleExpense {
  id          String   @id @default(uuid())
  vehicleId   String
  type        String
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model CashboxTransaction {
  id            String   @id @default(uuid())
  type          String
  amount        Float
  category      String
  description   String?
  userId        String
  userName      String
  reference     String?
  createdAt     DateTime @default(now())
  currency      String?  @default("UZS")
  paymentMethod String?  @default("CASH")

  @@index([type])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
}

model CustomerChat {
  id          String    @id @default(uuid())
  customerId  String
  adminId     String?
  message     String
  senderType  String
  messageType String    @default("TEXT")
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([customerId])
  @@index([adminId])
  @@index([createdAt])
  @@index([isRead])
}

model ProductVariant {
  id           String   @id @default(uuid())
  parentId     String
  variantName  String
  cardType     String?
  currentStock Int      @default(0)
  currentUnits Int      @default(0)
  pricePerBag  Float
  sku          String?  @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent       Product  @relation(fields: [parentId], references: [id])

  @@index([parentId])
}

model VariantStockMovement {
  id            String   @id @default(uuid())
  variantId     String
  type          String
  quantity      Int
  units         Int
  reason        String
  userId        String
  userName      String
  previousStock Int
  previousUnits Int
  newStock      Int
  newUnits      Int
  notes         String?
  createdAt     DateTime @default(now())
}

model VariantPriceHistory {
  id        String   @id @default(uuid())
  variantId String
  oldPrice  Float
  newPrice  Float
  reason    String?
  userId    String
  userName  String
  createdAt DateTime @default(now())
}

model BagLabel {
  id             String    @id @default(uuid())
  barcode        String
  productId      String
  productName    String
  productType    String
  unitsPerBag    Int
  bagNumber      Int
  workerId       String
  productionDate DateTime
  status         String    @default("IN_STOCK")
  printedAt      DateTime  @default(now())
  printedBy      String
  soldAt         DateTime?
  saleId         String?
  notes          String?
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String
  description String?
  parentId    String?
  managerId   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Position {
  id               String   @id @default(uuid())
  name             String
  code             String
  departmentId     String
  description      String?
  responsibilities String?
  requirements     String?
  salaryRangeMin   Float?
  salaryRangeMax   Float?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Employee {
  id                   String    @id @default(uuid())
  employeeCode         String
  firstName            String
  lastName             String
  middleName           String?
  fullName             String
  phone                String?
  email                String?
  address              String?
  emergencyContact     String?
  passportSeries       String?
  passportNumber       String?
  passportIssueDate    DateTime?
  passportIssueBy      String?
  birthDate            DateTime?
  birthPlace           String?
  nationality          String?
  departmentId         String
  positionId           String
  hireDate             DateTime
  fireDate             DateTime?
  employmentType       String    @default("FULL_TIME")
  workSchedule         String    @default("STANDARD")
  probationEnd         DateTime?
  salary               Float     @default(0)
  hourlyRate           Float?
  bankAccount          String?
  bankName             String?
  telegramChatId       String?
  telegramUsername     String?
  notificationsEnabled Boolean   @default(true)
  status               String    @default("ACTIVE")
  education            String?
  skills               String?
  certificates         String?
  photoUrl             String?
  notes                String?
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Attendance {
  id                String    @id @default(uuid())
  employeeId        String
  date              DateTime
  checkIn           DateTime?
  checkOut          DateTime?
  scheduledCheckIn  DateTime?
  scheduledCheckOut DateTime?
  workHours         Float     @default(0)
  overtime          Float     @default(0)
  lateMinutes       Int       @default(0)
  earlyLeaveMinutes Int       @default(0)
  status            String    @default("PRESENT")
  type              String    @default("WORK")
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model LeaveRequest {
  id            String    @id @default(uuid())
  employeeId    String
  leaveType     String
  startDate     DateTime
  endDate       DateTime
  days          Int
  reason        String
  description   String?
  attachmentUrl String?
  status        String    @default("PENDING")
  requestedAt   DateTime  @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmployeeApplication {
  id              String    @id @default(uuid())
  employeeId      String
  applicationType String
  title           String
  description     String
  status          String    @default("PENDING")
  priority        String    @default("NORMAL")
  response        String?
  respondedBy     String?
  respondedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmployeeMessage {
  id                String    @id @default(uuid())
  employeeId        String
  senderId          String
  senderName        String
  type              String    @default("EMAIL")
  subject           String
  content           String
  sentAt            DateTime  @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?
  telegramMessageId String?
  createdAt         DateTime  @default(now())
}

model Attestation {
  id              String   @id @default(uuid())
  employeeId      String
  attestationDate DateTime
  periodStart     DateTime
  periodEnd       DateTime
  performance     Int?
  discipline      Int?
  punctuality     Int?
  teamwork        Int?
  initiative      Int?
  overallScore    Float?
  grade           String?
  strengths       String?
  weaknesses      String?
  recommendations String?
  assessedBy      String
  assessedByName  String
  approvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Survey {
  id                String   @id @default(uuid())
  title             String
  description       String?
  targetType        String   @default("ALL")
  targetDepartments String?
  targetPositions   String?
  targetEmployees   String?
  startDate         DateTime
  endDate           DateTime
  questions         String
  status            String   @default("DRAFT")
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  employeeId  String
  answers     String
  submittedAt DateTime @default(now())
}

model WorkSchedule {
  id            String   @id @default(uuid())
  name          String
  scheduleType  String
  workDays      String
  workStartTime String
  workEndTime   String
  breakDuration Int      @default(60)
  shiftDays     Int?
  offDays       Int?
  departmentId  String?
  positionId    String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeTelegram {
  id               String   @id @default(uuid())
  employeeId       String
  telegramChatId   String
  telegramUsername String?
  isActive         Boolean  @default(true)
  registeredAt     DateTime @default(now())
  lastActivityAt   DateTime @default(now())
}

model EmployeeLoan {
  id              String    @id @default(uuid())
  employeeId      String
  amount          Float
  currency        String    @default("UZS")
  purpose         String
  description     String?
  dueDate         DateTime?
  interestRate    Float     @default(0)
  remainingAmount Float
  totalRepaid     Float     @default(0)
  status          String    @default("ACTIVE")
  issuedBy        String
  issuedByName    String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model LoanRepayment {
  id                String   @id @default(uuid())
  loanId            String
  amount            Float
  currency          String
  paymentMethod     String   @default("CASH")
  description       String?
  isSalaryDeduction Boolean  @default(false)
  payrollPeriod     String?
  receivedBy        String
  receivedByName    String
  createdAt         DateTime @default(now())
}

model Budget {
  id             String    @id @default(uuid())
  category       String
  year           Int
  month          Int
  amount         Float
  currency       String    @default("UZS")
  alertThreshold Float     @default(80)
  spent          Float     @default(0)
  remaining      Float
  status         String    @default("ACTIVE")
  description    String?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  closedAt       DateTime?
}

model BudgetAlert {
  id           String    @id @default(uuid())
  budgetId     String
  type         String
  category     String?
  threshold    Float
  currentUsage Float
  message      String
  isRead       Boolean   @default(false)
  readAt       DateTime?
  createdAt    DateTime  @default(now())
}

model Kit {
  id              String   @id @default(uuid())
  kitName         String
  description     String?
  price           Float
  discountPercent Float    @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model KitItem {
  id        String   @id @default(uuid())
  kitId     String
  productId String
  quantity  Int      @default(1)
  itemType  String   @default("bag")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model KitSale {
  id          String   @id @default(uuid())
  saleId      String
  kitId       String
  customerId  String?
  quantity    Int      @default(1)
  kitPrice    Float
  totalAmount Float
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
}
