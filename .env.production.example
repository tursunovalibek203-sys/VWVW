# Production Environment Variables

# Database
DATABASE_URL="postgresql://user:password@host:5432/aziztrades_erp"

# JWT Secret (Generate a strong random string)
JWT_SECRET="your-super-secret-production-jwt-key-min-32-chars"

# Server
PORT=5000
NODE_ENV=production

# CORS (Your frontend domain)
CORS_ORIGIN="https://yourdomain.com"

# Telegram Bot
TELEGRAM_BOT_TOKEN=""           # Customer bot token (mijozlar bilan)
TELEGRAM_ADMIN_BOT_TOKEN=""     # Admin bot token (admin xabarlari uchun)
TELEGRAM_ADMIN_CHAT_ID=""       # Admin Telegram chat ID (vergul bilan bir nechtasi mumkin)

# Telegram Savdolar Kanali (Forum/Topics rejimida supergroup)
# Bu group'da bot admin bo'lishi kerak, Forum mode yoniq bo'lishi kerak
# Group ID olish: @userinfobot yoki @getmyid_bot orqali (odatda manfiy raqam, masalan: -1001234567890)
TELEGRAM_SALES_CHANNEL_ID=""

# Exchange Rates
USD_TO_UZS_RATE=12500

# Redis (Optional - for caching)
REDIS_URL="redis://localhost:6379"

# Sentry (Optional - for error tracking)
SENTRY_DSN=""

# Email (Optional - for notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@aziztrades.com"
`